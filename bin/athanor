#!/usr/bin/env sh
# Resolve the directory this script lives in, following symlinks.
SCRIPT="$0"
while [ -L "$SCRIPT" ]; do
  DIR="$(cd -P "$(dirname "$SCRIPT")" && pwd)"
  SCRIPT="$(readlink "$SCRIPT")"
  case "$SCRIPT" in /*) ;; *) SCRIPT="$DIR/$SCRIPT" ;; esac
done
HARNESS_DIR="$(cd -P "$(dirname "$SCRIPT")/.." && pwd)"

exec "${HARNESS_DIR}/node_modules/.bin/tsx" "${HARNESS_DIR}/src/cli.ts" "$@"
