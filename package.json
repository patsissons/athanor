{
  "name": "harness",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "athanor": "./bin/athanor"
  },
  "scripts": {
    "harness": "tsx src/cli.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "vitest run --config src/vitest.config.ts",
    "test:e2e": "vitest run src/orchestrator.e2e.test.ts",
    "validate": "npm run format:check && npm run typecheck && npm run lint && npm test",
    "format-and-validate": "npm run format && npm run validate"
  },
  "type": "module",
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "chalk": "5.6.2",
    "commander": "^14.0.3",
    "execa": "9.6.1",
    "minimatch": "10.2.5",
    "yaml": "2.8.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/minimatch": "5.1.2",
    "@types/node": "25.6.0",
    "eslint": "^9",
    "globals": "^16.4.0",
    "prettier": "3.8.3",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  }
}
